<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>EduTrack — لوحة المتابعة</title>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.4/chart.umd.min.js"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;900&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --ink:#152a45;
    --ink-2:#1e3c63;
    --paper:#f5f2ea;
    --card:#ffffff;
    --line:rgba(21,42,69,0.13);
    --gold:#b8892b;
    --gold-soft:rgba(184,137,43,0.13);
    --success:#2e7d52;
    --success-soft:rgba(46,125,82,0.12);
    --error:#a3342a;
    --error-soft:rgba(163,52,42,0.11);
    --muted:#6a7688;
  }
  *{ margin:0; padding:0; box-sizing:border-box; }
  html,body{ height:100%; }
  body{
    font-family:'Tajawal',sans-serif;
    background:
      radial-gradient(1100px 500px at 85% -10%, rgba(184,137,43,0.08), transparent 60%),
      var(--paper);
    color:var(--ink);
    min-height:100vh;
    padding:28px 22px 60px;
  }
  .num{ font-family:'Space Grotesk',sans-serif; }

  /* ===== Header ===== */
  .topbar{
    max-width:1180px; margin:0 auto 22px;
    display:flex; align-items:center; justify-content:space-between; gap:16px; flex-wrap:wrap;
  }
  .brand{ display:flex; align-items:center; gap:12px; }
  .brand-mark{
    width:44px; height:44px; border-radius:12px;
    background:linear-gradient(135deg, var(--ink), var(--ink-2));
    color:#f5efe0; display:flex; align-items:center; justify-content:center;
    font-family:'Space Grotesk',sans-serif; font-weight:700; font-size:15px;
    box-shadow:0 6px 16px rgba(21,42,69,0.28);
  }
  .brand h1{ font-size:19px; font-weight:900; color:var(--ink); }
  .brand p{ font-size:12px; color:var(--muted); margin-top:1px; }
  .top-actions{ display:flex; align-items:center; gap:10px; }
  .updated-note{ font-size:11.5px; color:var(--muted); }
  .refresh-btn{
    display:flex; align-items:center; gap:7px;
    padding:10px 16px; border-radius:10px; border:1px solid var(--line);
    background:var(--card); color:var(--ink); font-family:'Tajawal',sans-serif;
    font-weight:700; font-size:13px; cursor:pointer; transition:all .15s ease;
    box-shadow:0 1px 2px rgba(21,42,69,0.05);
  }
  .refresh-btn:hover{ border-color:var(--gold); color:var(--gold); transform:translateY(-1px); }
  .refresh-btn .spin{ display:inline-block; }
  .refresh-btn.loading .spin{ animation:spin .8s linear infinite; }
  @keyframes spin{ to{ transform:rotate(360deg); } }

  .wrap{ max-width:1180px; margin:0 auto; }

  /* ===== Ledger tab grade switcher (signature element) ===== */
  .tab-row{ display:flex; align-items:flex-end; margin-bottom:0; padding-inline-start:6px; }
  .tab{
    position:relative; cursor:pointer; user-select:none;
    padding:11px 22px 13px; margin-inline-end:-10px;
    background:#ece7d9; color:var(--muted); font-weight:700; font-size:13.5px;
    border-radius:12px 12px 0 0; border:1px solid var(--line); border-bottom:none;
    transition:all .18s ease; z-index:1;
  }
  .tab:hover{ color:var(--ink); }
  .tab.active{
    background:var(--card); color:var(--ink); z-index:5;
    box-shadow:0 -3px 10px rgba(21,42,69,0.06);
  }
  .tab.active::after{
    content:""; position:absolute; left:0; right:0; bottom:-1px; height:3px;
    background:var(--gold); border-radius:3px 3px 0 0;
  }
  .tab-panel{
    background:var(--card); border:1px solid var(--line); border-radius:0 14px 14px 14px;
    padding:26px; box-shadow:0 4px 22px rgba(21,42,69,0.06); position:relative; z-index:4;
  }

  .state-msg{
    display:none; align-items:center; justify-content:center; gap:10px;
    padding:60px 10px; color:var(--muted); font-size:13.5px; text-align:center;
  }
  .state-msg.show{ display:flex; }
  .state-msg.err{ color:var(--error); flex-direction:column; gap:8px; }
  .state-msg .spinner{
    width:18px; height:18px; border-radius:50%; border:2px solid rgba(21,42,69,0.15);
    border-top-color:var(--gold); animation:spin .7s linear infinite; flex-shrink:0;
  }
  .content{ display:none; }
  .content.show{ display:block; }

  /* ===== KPI cards ===== */
  .kpi-grid{ display:grid; grid-template-columns:repeat(5,1fr); gap:12px; margin-bottom:24px; }
  .kpi-card{
    background:var(--paper); border:1px solid var(--line); border-radius:14px;
    padding:16px 16px 14px; position:relative; overflow:hidden;
  }
  .kpi-label{ font-size:11px; color:var(--muted); font-weight:700; letter-spacing:.01em; margin-bottom:8px; }
  .kpi-value{ font-size:24px; font-weight:700; color:var(--ink); line-height:1; }
  .kpi-sub{ font-size:11px; color:var(--muted); margin-top:7px; }
  .kpi-card.seal{
    display:flex; align-items:center; gap:12px; justify-content:flex-start;
  }
  .seal-ring{ position:relative; width:58px; height:58px; flex-shrink:0; }
  .seal-ring svg{ transform:rotate(-90deg); }
  .seal-ring .bg{ stroke:rgba(21,42,69,0.1); }
  .seal-ring .fg{ stroke:var(--gold); stroke-linecap:round; transition:stroke-dashoffset .6s ease; }
  .seal-pct{
    position:absolute; inset:0; display:flex; align-items:center; justify-content:center;
    font-family:'Space Grotesk',sans-serif; font-weight:700; font-size:13px; color:var(--ink);
  }

  /* ===== Section headers ===== */
  .section-title{
    display:flex; align-items:center; gap:8px;
    font-weight:700; font-size:14.5px; color:var(--ink); margin-bottom:12px;
  }
  .section-title .tag{
    font-size:10.5px; font-weight:700; color:var(--gold); background:var(--gold-soft);
    padding:3px 8px; border-radius:999px;
  }

  .two-col{ display:grid; grid-template-columns:1.2fr 1fr; gap:16px; margin-bottom:24px; }
  .chart-card{
    background:var(--paper); border:1px solid var(--line); border-radius:14px; padding:16px;
  }
  .chart-box{ position:relative; height:220px; }
  .chart-empty{
    position:absolute; inset:0; display:none; align-items:center; justify-content:center;
    color:var(--muted); font-size:12.5px; text-align:center; padding:0 20px;
  }
  .chart-empty.show{ display:flex; }

  /* ===== Lists ===== */
  .list-grid{ display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:24px; }
  .list-card{ background:var(--paper); border:1px solid var(--line); border-radius:14px; padding:16px; }
  .list-row{
    display:flex; align-items:center; justify-content:space-between; gap:10px;
    padding:10px 4px; border-bottom:1px solid var(--line); font-size:13px;
  }
  .list-row:last-child{ border-bottom:none; }
  .list-name{ display:flex; align-items:center; gap:9px; min-width:0; }
  .list-name .name{ font-weight:600; color:var(--ink); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; max-width:150px; }
  .list-name .grade-chip{
    font-size:9.5px; font-weight:700; color:var(--ink-2); background:rgba(30,60,99,0.08);
    padding:2px 7px; border-radius:999px; flex-shrink:0;
  }
  .rank{
    display:inline-flex; align-items:center; justify-content:center; width:20px; height:20px;
    border-radius:6px; font-size:10.5px; font-weight:700; background:var(--gold-soft); color:var(--gold);
    flex-shrink:0;
  }
  .val{ font-family:'Space Grotesk',sans-serif; font-weight:700; color:var(--ink); flex-shrink:0; }
  .phone-link{
    font-size:11px; color:var(--muted); text-decoration:none; direction:ltr; display:inline-block;
  }
  .phone-link:hover{ color:var(--gold); }
  .empty-note{ text-align:center; color:var(--muted); font-size:12.5px; padding:20px 0; }

  /* ===== Roster table ===== */
  .roster-head{ display:flex; align-items:center; justify-content:space-between; gap:12px; margin-bottom:12px; flex-wrap:wrap; }
  .search-box{
    flex:1; min-width:200px; position:relative;
  }
  .search-box input{
    width:100%; padding:10px 14px; border-radius:10px; border:1px solid var(--line);
    background:var(--card); font-family:'Tajawal',sans-serif; font-size:13px; outline:none; color:var(--ink);
  }
  .search-box input:focus{ border-color:var(--gold); }
  .pay-filter{ display:flex; gap:6px; }
  .pay-filter button{
    padding:9px 13px; border-radius:9px; border:1px solid var(--line); background:var(--card);
    color:var(--muted); font-family:'Tajawal',sans-serif; font-size:12px; font-weight:700; cursor:pointer;
  }
  .pay-filter button.active{ background:var(--ink); color:#fff; border-color:var(--ink); }

  .table-wrap{ overflow-x:auto; border:1px solid var(--line); border-radius:12px; }
  table{ width:100%; border-collapse:collapse; font-size:12.5px; min-width:640px; }
  thead th{
    text-align:right; padding:11px 12px; background:var(--paper); color:var(--muted);
    font-weight:700; font-size:11px; text-transform:uppercase; letter-spacing:.03em;
    border-bottom:1px solid var(--line); white-space:nowrap;
  }
  tbody td{ padding:10px 12px; border-bottom:1px solid var(--line); color:var(--ink); white-space:nowrap; }
  tbody tr:last-child td{ border-bottom:none; }
  tbody tr:hover{ background:rgba(184,137,43,0.05); }
  .chip{ display:inline-block; padding:3px 10px; border-radius:999px; font-size:11px; font-weight:700; }
  .chip.paid{ background:var(--success-soft); color:var(--success); }
  .chip.unpaid{ background:var(--error-soft); color:var(--error); }
  .bar-track{ width:70px; height:6px; border-radius:4px; background:rgba(21,42,69,0.08); display:inline-block; vertical-align:middle; margin-inline-end:6px; }
  .bar-fill{ height:100%; border-radius:4px; background:var(--gold); }

  .footer-note{ text-align:center; font-size:11.5px; color:var(--muted); margin-top:26px; }

  @media (max-width:900px){
    .kpi-grid{ grid-template-columns:repeat(2,1fr); }
    .two-col, .list-grid{ grid-template-columns:1fr; }
  }
  @media (prefers-reduced-motion: reduce){
    .refresh-btn .spin, .state-msg .spinner{ animation:none !important; }
  }
</style>
</head>
<body>

<div class="topbar">
  <div class="brand">
    <div class="brand-mark">ET</div>
    <div>
      <h1>EduTrack — لوحة المتابعة</h1>
      <p>حضور وتحصيل مباشر من قاعدة البيانات</p>
    </div>
  </div>
  <div class="top-actions">
    <span class="updated-note" id="updatedNote"></span>
    <button class="refresh-btn" id="refreshBtn" onclick="loadDashboard()">
      <span class="spin">↻</span> تحديث البيانات
    </button>
  </div>
</div>

<div class="wrap">
  <div class="tab-row" id="gradeTabs">
    <div class="tab active" data-grade="all">كل الصفوف</div>
    <div class="tab" data-grade="first">الصف الأول الثانوي</div>
    <div class="tab" data-grade="second">الصف الثاني الثانوي</div>
    <div class="tab" data-grade="third">الصف الثالث الثانوي</div>
  </div>

  <div class="tab-panel">
    <div class="state-msg show" id="loadingMsg">
      <span class="spinner"></span> جاري تحميل البيانات من Supabase…
    </div>
    <div class="state-msg err" id="errorMsg"></div>

    <div class="content" id="dashContent">

      <div class="kpi-grid">
        <div class="kpi-card">
          <div class="kpi-label">إجمالي الطلاب</div>
          <div class="kpi-value num" id="kpiStudents">–</div>
          <div class="kpi-sub" id="kpiStudentsSub"></div>
        </div>
        <div class="kpi-card">
          <div class="kpi-label">نسبة الحضور</div>
          <div class="kpi-value num" id="kpiAttendance">–</div>
          <div class="kpi-sub" id="kpiAttendanceSub"></div>
        </div>
        <div class="kpi-card">
          <div class="kpi-label">إجمالي المحصّل</div>
          <div class="kpi-value num" id="kpiRevenue">–</div>
          <div class="kpi-sub" id="kpiRevenueSub"></div>
        </div>
        <div class="kpi-card">
          <div class="kpi-label">لم يسددوا</div>
          <div class="kpi-value num" id="kpiUnpaid">–</div>
          <div class="kpi-sub" id="kpiUnpaidSub"></div>
        </div>
        <div class="kpi-card seal">
          <div class="seal-ring">
            <svg width="58" height="58" viewBox="0 0 58 58">
              <circle class="bg" cx="29" cy="29" r="24" fill="none" stroke-width="6"></circle>
              <circle class="fg" id="collectionRing" cx="29" cy="29" r="24" fill="none" stroke-width="6"
                stroke-dasharray="150.8" stroke-dashoffset="150.8"></circle>
            </svg>
            <div class="seal-pct" id="collectionPctText">–</div>
          </div>
          <div>
            <div class="kpi-label">نسبة التحصيل</div>
            <div class="kpi-sub" id="kpiCollectionSub" style="margin-top:4px;">من إجمالي المطلوب دفعه</div>
          </div>
        </div>
      </div>

      <div class="two-col">
        <div class="chart-card">
          <div class="section-title">نسبة الحضور حسب الصف <span class="tag">Live</span></div>
          <div class="chart-box">
            <canvas id="attendanceByGradeChart"></canvas>
            <div class="chart-empty" id="attChartEmpty">لا توجد بيانات حضور بعد</div>
          </div>
        </div>
        <div class="chart-card">
          <div class="section-title">حالة السداد</div>
          <div class="chart-box">
            <canvas id="paymentStatusChart"></canvas>
            <div class="chart-empty" id="payChartEmpty">لا توجد بيانات سداد بعد</div>
          </div>
        </div>
      </div>

      <div class="chart-card" style="margin-bottom:24px;">
        <div class="section-title">الإيراد الشهري <span class="tag" id="revenueSourceTag">monthly_statistics</span></div>
        <div class="chart-box" style="height:190px;">
          <canvas id="revenueChart"></canvas>
          <div class="chart-empty" id="revChartEmpty">لا توجد بيانات إيراد شهري مسجلة بعد</div>
        </div>
      </div>

      <div class="list-grid">
        <div class="list-card">
          <div class="section-title">🏆 الأعلى حضورًا</div>
          <div id="topAttendersList"></div>
        </div>
        <div class="list-card">
          <div class="section-title">📵 لم يسددوا الرسوم</div>
          <div id="unpaidList"></div>
        </div>
      </div>

      <div class="chart-card">
        <div class="roster-head">
          <div class="search-box">
            <input type="text" id="rosterSearch" placeholder="ابحث بالاسم أو رقم الهاتف أو كود QR…" oninput="renderRoster()">
          </div>
          <div class="pay-filter" id="payFilter">
            <button class="active" data-f="all" onclick="setPayFilter('all')">الكل</button>
            <button data-f="paid" onclick="setPayFilter('paid')">مسدد</button>
            <button data-f="unpaid" onclick="setPayFilter('unpaid')">غير مسدد</button>
          </div>
        </div>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>الاسم</th>
                <th>الصف</th>
                <th>الحضور</th>
                <th>الغياب</th>
                <th>نسبة الحضور</th>
                <th>هاتف ولي الأمر</th>
                <th>السداد</th>
                <th>آخر حضور</th>
              </tr>
            </thead>
            <tbody id="rosterBody"></tbody>
          </table>
        </div>
      </div>

    </div>
  </div>

  <div class="footer-note">تُقرأ البيانات مباشرة من Supabase عبر مفتاح anon للقراءة فقط</div>
</div>

<script>
  /* ============================================================
     SUPABASE CONNECTION
     ============================================================ */
  const SUPABASE_URL = "https://evbjulsahncllewwvlxp.supabase.co";
  const SUPABASE_ANON_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImV2Ymp1bHNhaG5jbGxld3d2bHhwIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODM2NzE5MjUsImV4cCI6MjA5OTI0NzkyNX0.Xg9sU6ZenUU3kC2RNIbvZmK19KvE28MM2oyGcKNn8UA";
  const supa = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

  // Change only the right-hand side here if your real column/table names differ.
  const SCHEMA = {
    attendanceTable: (g) => `attendance_${g}_secondary`,
    paymentsTable: (g) => `payments_${g}_secondary`,
    statsTable: "monthly_statistics",
    col: {
      fullName: "full_name",
      qrCode: "qr_code",
      studentPhone: "student_phone",
      parentPhone: "parent_phone",
      attendanceCount: "attendance_count",
      absenceCount: "absence_count",
      lastAttendance: "last_attendance",
      amountPaid: "amount_paid",
      paymentStatus: "payment_status",
      lastPaymentDate: "last_payment_date",
      statsGrade: "grade",
      statsMonth: "month",
      statsYear: "year",
      statsRevenue: "revenue"
    }
  };

  const GRADE_LABELS = { first: "الصف الأول", second: "الصف الثاني", third: "الصف الثالث" };
  const GRADES = ["first", "second", "third"];

  let currentGrade = "all";
  let payFilterState = "all";
  let combined = { students: [], statsRows: [] }; // students = merged attendance+payment rows, tagged with grade
  let charts = {};

  /* ---------- Tabs ---------- */
  document.querySelectorAll("#gradeTabs .tab").forEach(tab => {
    tab.addEventListener("click", () => {
      document.querySelectorAll("#gradeTabs .tab").forEach(t => t.classList.remove("active"));
      tab.classList.add("active");
      currentGrade = tab.dataset.grade;
      loadDashboard();
    });
  });

  function setPayFilter(f){
    payFilterState = f;
    document.querySelectorAll("#payFilter button").forEach(b => b.classList.toggle("active", b.dataset.f === f));
    renderRoster();
  }

  /* ---------- Helpers ---------- */
  function isPaid(status){
    const s = String(status ?? "").trim().toLowerCase();
    return s === "paid" || s === "true" || s === "yes" || s === "مدفوع" || s === "1";
  }
  function pct(att, abs){
    const a = Number(att) || 0, b = Number(abs) || 0;
    const total = a + b;
    return total > 0 ? Math.round((a / total) * 100) : null;
  }
  function fmtEGP(n){ return `${Number(n || 0).toLocaleString('en-US')} ج.م`; }

  /* ---------- Fetch + merge one grade ---------- */
  async function fetchGrade(grade){
    const [{ data: att, error: attErr }, { data: pay, error: payErr }] = await Promise.all([
      supa.from(SCHEMA.attendanceTable(grade)).select("*"),
      supa.from(SCHEMA.paymentsTable(grade)).select("*")
    ]);
    if(attErr) throw new Error(`(${SCHEMA.attendanceTable(grade)}) ${attErr.message}`);
    if(payErr) throw new Error(`(${SCHEMA.paymentsTable(grade)}) ${payErr.message}`);

    const col = SCHEMA.col;
    // Index payments by qr_code so we can attach payment info to each attendance row.
    const payByCode = {};
    (pay || []).forEach(p => { payByCode[p[col.qrCode]] = p; });

    return (att || []).map(a => {
      const p = payByCode[a[col.qrCode]] || {};
      return {
        grade,
        name: a[col.fullName] ?? "",
        qrCode: a[col.qrCode] ?? "",
        studentPhone: a[col.studentPhone] ?? "",
        parentPhone: a[col.parentPhone] ?? "",
        attendanceCount: Number(a[col.attendanceCount] || 0),
        absenceCount: Number(a[col.absenceCount] || 0),
        lastAttendance: a[col.lastAttendance] ?? "",
        paymentStatus: p[col.paymentStatus] ?? "",
        amountPaid: Number(p[col.amountPaid] || 0),
        lastPaymentDate: p[col.lastPaymentDate] ?? ""
      };
    });
  }

  async function fetchStats(){
    try{
      let q = supa.from(SCHEMA.statsTable).select("*");
      const { data, error } = await q;
      if(error) throw error;
      return data || [];
    }catch(e){
      return []; // stats table is optional — dashboard still works without it
    }
  }

  /* ---------- Main load ---------- */
  async function loadDashboard(){
    const loadingEl = document.getElementById("loadingMsg");
    const errorEl = document.getElementById("errorMsg");
    const contentEl = document.getElementById("dashContent");
    const btn = document.getElementById("refreshBtn");

    btn.classList.add("loading");
    loadingEl.classList.add("show");
    errorEl.classList.remove("show");
    contentEl.classList.remove("show");

    try{
      const gradesToFetch = currentGrade === "all" ? GRADES : [currentGrade];
      const results = await Promise.all(gradesToFetch.map(fetchGrade));
      combined.students = results.flat();
      combined.statsRows = await fetchStats();

      renderAll();
      contentEl.classList.add("show");
      document.getElementById("updatedNote").textContent =
        "آخر تحديث: " + new Date().toLocaleTimeString("ar-EG", { hour: "2-digit", minute: "2-digit" });
    }catch(err){
      console.error(err);
      errorEl.innerHTML = `
        <div style="font-weight:700;">تعذّر تحميل البيانات من Supabase</div>
        <div style="font-size:12px; max-width:520px;">
          ${err.message || err}<br><br>
          الأسباب الشائعة: أسماء الجداول/الأعمدة في SCHEMA لا تطابق قاعدة البيانات فعليًا،
          أو أن Row Level Security مفعّل على الجداول بدون سياسة SELECT تسمح لدور anon بالقراءة —
          هذا هو السبب الأكثر شيوعًا لظهور 0 في كل مكان رغم وجود بيانات في Table Editor
          (لأن Table Editor يستخدم صلاحيات أعلى من مفتاح anon).
        </div>`;
      errorEl.classList.add("show");
    }finally{
      loadingEl.classList.remove("show");
      btn.classList.remove("loading");
    }
  }

  /* ---------- Render everything ---------- */
  function renderAll(){
    const students = combined.students;
    const col = SCHEMA.col;

    // ---- KPIs ----
    const studentsCount = students.length;
    const pcts = students.map(s => pct(s.attendanceCount, s.absenceCount)).filter(v => v != null);
    const attendanceRate = pcts.length ? Math.round(pcts.reduce((a,b)=>a+b,0) / pcts.length) : null;

    const paidStudents = students.filter(s => isPaid(s.paymentStatus));
    const unpaidStudents = students.filter(s => !isPaid(s.paymentStatus) && s.paymentStatus !== "");
    const withPaymentRecord = students.filter(s => s.paymentStatus !== "");
    const collectionRate = withPaymentRecord.length ? Math.round((paidStudents.length / withPaymentRecord.length) * 100) : null;
    const totalRevenue = paidStudents.reduce((sum, s) => sum + (s.amountPaid || 0), 0);

    document.getElementById("kpiStudents").textContent = studentsCount;
    document.getElementById("kpiStudentsSub").textContent =
      currentGrade === "all" ? "في كل الصفوف" : GRADE_LABELS[currentGrade];

    document.getElementById("kpiAttendance").textContent = attendanceRate != null ? `${attendanceRate}%` : "–";
    document.getElementById("kpiAttendanceSub").textContent = pcts.length ? `متوسط ${pcts.length} طالب` : "لا بيانات حضور";

    document.getElementById("kpiRevenue").textContent = fmtEGP(totalRevenue);
    document.getElementById("kpiRevenueSub").textContent =
      (totalRevenue === 0 && paidStudents.length > 0)
        ? "⚠️ عدد المسددين > 0 لكن amount_paid = 0 — تحقّق من ورك فلو الدفع"
        : `${paidStudents.length} طالب مسدد`;

    document.getElementById("kpiUnpaid").textContent = unpaidStudents.length;
    document.getElementById("kpiUnpaidSub").textContent = withPaymentRecord.length ? `من أصل ${withPaymentRecord.length}` : "لا سجلات دفع";

    document.getElementById("kpiCollectionSub").textContent = "من إجمالي المطلوب دفعه";
    const ringEl = document.getElementById("collectionRing");
    const circumference = 150.8;
    if(collectionRate != null){
      ringEl.style.strokeDashoffset = String(circumference - (circumference * collectionRate / 100));
      document.getElementById("collectionPctText").textContent = `${collectionRate}%`;
    } else {
      ringEl.style.strokeDashoffset = String(circumference);
      document.getElementById("collectionPctText").textContent = "–";
    }

    renderAttendanceByGradeChart(students);
    renderPaymentStatusChart(paidStudents.length, unpaidStudents.length);
    renderRevenueChart();
    renderTopAttenders(students);
    renderUnpaidList(unpaidStudents);
    payFilterState = "all";
    document.querySelectorAll("#payFilter button").forEach(b => b.classList.toggle("active", b.dataset.f === "all"));
    document.getElementById("rosterSearch").value = "";
    renderRoster();
  }

  function destroyChart(key){ if(charts[key]){ charts[key].destroy(); charts[key] = null; } }

  function renderAttendanceByGradeChart(students){
    const canvas = document.getElementById("attendanceByGradeChart");
    const emptyEl = document.getElementById("attChartEmpty");
    destroyChart("att");

    const gradesShown = currentGrade === "all" ? GRADES : [currentGrade];
    const rows = gradesShown.map(g => {
      const gs = students.filter(s => s.grade === g);
      const pcts = gs.map(s => pct(s.attendanceCount, s.absenceCount)).filter(v => v != null);
      return { grade: g, rate: pcts.length ? Math.round(pcts.reduce((a,b)=>a+b,0)/pcts.length) : null };
    });
    const hasData = rows.some(r => r.rate != null);
    if(!hasData){ canvas.style.display = "none"; emptyEl.classList.add("show"); return; }
    canvas.style.display = "block"; emptyEl.classList.remove("show");

    charts.att = new Chart(canvas, {
      type: "bar",
      data: {
        labels: rows.map(r => GRADE_LABELS[r.grade]),
        datasets: [{
          data: rows.map(r => r.rate ?? 0),
          backgroundColor: "rgba(184,137,43,0.65)",
          borderRadius: 6, maxBarThickness: 46
        }]
      },
      options: {
        maintainAspectRatio: false,
        plugins: { legend: { display: false }, tooltip: { callbacks: { label: c => `${c.raw}%` } } },
        scales: {
          y: { beginAtZero: true, max: 100, ticks: { callback: v => v + "%", font: { size: 10 } }, grid: { color: "rgba(21,42,69,0.06)" } },
          x: { ticks: { font: { size: 11, family: "Tajawal" } }, grid: { display: false } }
        }
      }
    });
  }

  function renderPaymentStatusChart(paidCount, unpaidCount){
    const canvas = document.getElementById("paymentStatusChart");
    const emptyEl = document.getElementById("payChartEmpty");
    destroyChart("pay");

    if(paidCount + unpaidCount === 0){ canvas.style.display = "none"; emptyEl.classList.add("show"); return; }
    canvas.style.display = "block"; emptyEl.classList.remove("show");

    charts.pay = new Chart(canvas, {
      type: "doughnut",
      data: {
        labels: ["مسدد", "غير مسدد"],
        datasets: [{
          data: [paidCount, unpaidCount],
          backgroundColor: ["rgba(46,125,82,0.75)", "rgba(163,52,42,0.7)"],
          borderWidth: 0
        }]
      },
      options: {
        maintainAspectRatio: false, cutout: "68%",
        plugins: { legend: { position: "bottom", labels: { font: { family: "Tajawal", size: 12 }, padding: 14 } } }
      }
    });
  }

  function renderRevenueChart(){
    const canvas = document.getElementById("revenueChart");
    const emptyEl = document.getElementById("revChartEmpty");
    destroyChart("rev");
    const col = SCHEMA.col;

    let rows = combined.statsRows || [];
    if(currentGrade !== "all"){
      rows = rows.filter(r => r[col.statsGrade] === currentGrade);
    }
    if(!rows.length){ canvas.style.display = "none"; emptyEl.classList.add("show"); return; }

    // Aggregate by month/year (summing across grades when viewing "all")
    const byKey = {};
    rows.forEach(r => {
      const key = `${r[col.statsYear]}-${String(r[col.statsMonth]).padStart(2,"0")}`;
      byKey[key] = (byKey[key] || 0) + (Number(r[col.statsRevenue]) || 0);
    });
    const sortedKeys = Object.keys(byKey).sort().slice(-6);
    if(!sortedKeys.length){ canvas.style.display = "none"; emptyEl.classList.add("show"); return; }

    canvas.style.display = "block"; emptyEl.classList.remove("show");
    charts.rev = new Chart(canvas, {
      type: "bar",
      data: {
        labels: sortedKeys,
        datasets: [{
          data: sortedKeys.map(k => byKey[k]),
          backgroundColor: "rgba(30,60,99,0.7)",
          borderRadius: 5, maxBarThickness: 30
        }]
      },
      options: {
        maintainAspectRatio: false,
        plugins: { legend: { display: false }, tooltip: { callbacks: { label: c => fmtEGP(c.raw) } } },
        scales: {
          y: { beginAtZero: true, ticks: { font: { size: 10 } }, grid: { color: "rgba(21,42,69,0.06)" } },
          x: { ticks: { font: { size: 10 } }, grid: { display: false } }
        }
      }
    });
  }

  function renderTopAttenders(students){
    const el = document.getElementById("topAttendersList");
    const top = [...students]
      .map(s => ({ ...s, p: pct(s.attendanceCount, s.absenceCount) }))
      .filter(s => s.p != null)
      .sort((a,b) => b.p - a.p || b.attendanceCount - a.attendanceCount)
      .slice(0, 6);
    if(!top.length){ el.innerHTML = `<div class="empty-note">لا توجد بيانات بعد</div>`; return; }
    el.innerHTML = top.map((s,i) => `
      <div class="list-row">
        <div class="list-name">
          <span class="rank">${i+1}</span>
          <span class="name">${s.name}</span>
          ${currentGrade === "all" ? `<span class="grade-chip">${GRADE_LABELS[s.grade]}</span>` : ""}
        </div>
        <div class="val">${s.p}%</div>
      </div>
    `).join("");
  }

  function renderUnpaidList(unpaidStudents){
    const el = document.getElementById("unpaidList");
    if(!unpaidStudents.length){ el.innerHTML = `<div class="empty-note">🎉 الجميع سدّد الرسوم</div>`; return; }
    el.innerHTML = unpaidStudents.slice(0, 8).map(s => `
      <div class="list-row">
        <div class="list-name">
          <span class="name">${s.name}</span>
          ${currentGrade === "all" ? `<span class="grade-chip">${GRADE_LABELS[s.grade]}</span>` : ""}
        </div>
        ${s.parentPhone ? `<a class="phone-link" href="tel:${s.parentPhone}">${s.parentPhone}</a>` : `<span class="empty-note" style="padding:0;">—</span>`}
      </div>
    `).join("") + (unpaidStudents.length > 8 ? `<div class="empty-note">+${unpaidStudents.length - 8} طالب آخر — راجع الجدول أدناه</div>` : "");
  }

  /* ---------- Roster table ---------- */
  function renderRoster(){
    const q = document.getElementById("rosterSearch").value.trim().toLowerCase();
    let rows = combined.students;

    if(payFilterState === "paid") rows = rows.filter(s => isPaid(s.paymentStatus));
    if(payFilterState === "unpaid") rows = rows.filter(s => !isPaid(s.paymentStatus));

    if(q){
      rows = rows.filter(s =>
        (s.name || "").toLowerCase().includes(q) ||
        (s.studentPhone || "").includes(q) ||
        (s.parentPhone || "").includes(q) ||
        (s.qrCode || "").toLowerCase().includes(q)
      );
    }

    const body = document.getElementById("rosterBody");
    if(!rows.length){
      body.innerHTML = `<tr><td colspan="8" style="text-align:center; color:var(--muted); padding:22px;">لا توجد نتائج مطابقة</td></tr>`;
      return;
    }

    body.innerHTML = rows.map(s => {
      const p = pct(s.attendanceCount, s.absenceCount);
      const paid = isPaid(s.paymentStatus);
      const hasPaymentRecord = s.paymentStatus !== "";
      return `
        <tr>
          <td style="font-weight:600;">${s.name || "—"}</td>
          <td>${GRADE_LABELS[s.grade] || "—"}</td>
          <td>${s.attendanceCount}</td>
          <td>${s.absenceCount}</td>
          <td>
            ${p != null ? `<span class="bar-track"><span class="bar-fill" style="width:${p}%;"></span></span>${p}%` : "—"}
          </td>
          <td>${s.parentPhone ? `<a class="phone-link" href="tel:${s.parentPhone}">${s.parentPhone}</a>` : "—"}</td>
          <td>${hasPaymentRecord ? `<span class="chip ${paid ? 'paid' : 'unpaid'}">${paid ? 'مسدد' : 'غير مسدد'}</span>` : "—"}</td>
          <td>${s.lastAttendance || "—"}</td>
        </tr>`;
    }).join("");
  }

  loadDashboard();
</script>
</body>
</html>
